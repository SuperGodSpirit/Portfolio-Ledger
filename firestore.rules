rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // 1. Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 2. Fetch the user's document from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 3. Is the user active?
    function isActiveUser() {
      let user = getUserData();
      return isAuthenticated() && (user.get('status', '') == 'active' || user.get('active', true) == true);
    }

    // 4. Is the user an owner or manager?
    function isOwnerOrManager() {
      let role = getUserData().get('role', '');
      return role == 'owner' || role == 'manager';
    }

    // 5. Check if user has explicit access to a specific portfolio
    function hasPortfolioAccess(portfolioId) {
      let user = getUserData();
      let hasDynamicAccess = user.get('portfolios', []).hasAny([portfolioId]);
      let hasLegacyAlpha = portfolioId == 'portfolioAlpha' && (user.get('portfolioAlpha', false) == true || user.get('PortfolioAlpha', false) == true);
      let hasLegacyBeta = portfolioId == 'portfolioBeta' && (user.get('portfolioBeta', false) == true || user.get('PortfolioBeta', false) == true);
      return hasDynamicAccess || hasLegacyAlpha || hasLegacyBeta;
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || (isActiveUser() && isOwnerOrManager()));
      allow create: if isAuthenticated() 
        && request.auth.uid == userId 
        && request.resource.data.role == 'viewer'
        && request.resource.data.status == 'pending'
        && request.resource.data.portfolios.size() == 0;
      allow update, delete: if isActiveUser() && isOwnerOrManager();
    }

    // ==========================================
    // PORTFOLIOS COLLECTION
    // ==========================================
    match /portfolios/{portfolioId} {
      allow read: if isActiveUser() && (isOwnerOrManager() || hasPortfolioAccess(portfolioId));
      allow write: if isActiveUser() && isOwnerOrManager();
      
      // PSR Versions Subcollection
      match /psrVersions/{versionId} {
        allow read: if isActiveUser() && (isOwnerOrManager() || hasPortfolioAccess(portfolioId));
        allow write: if isActiveUser() && isOwnerOrManager();
      }
    }

    // ==========================================
    // PROFIT SHARING RATIOS
    // ==========================================
    match /profit_sharing_ratios/{portfolioId} {
      allow read: if isActiveUser() && (isOwnerOrManager() || hasPortfolioAccess(portfolioId));
      allow write: if isActiveUser() && isOwnerOrManager();
    }

    match /psr_history/{historyId} {
      allow read: if isActiveUser() && (isOwnerOrManager() || hasPortfolioAccess(resource.data.portfolioId));
      allow create: if isActiveUser() && isOwnerOrManager();
      allow update, delete: if false; 
    }

    // ==========================================
    // IPOS COLLECTION
    // ==========================================
    match /ipos/{ipoId} {
      allow read: if isActiveUser() && (isOwnerOrManager() || hasPortfolioAccess(resource.data.portfolioId));
      allow write: if isActiveUser() && isOwnerOrManager();
    }

    // ==========================================
    // MARKET IPOS COLLECTION
    // ==========================================
    match /market_ipos/{ipoId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend scraper
    }
    match /market_ipos_meta/{metaId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // ==========================================
    // AUDIT LOGS COLLECTION
    // ==========================================
    match /audit_logs/{logId} {
      allow read: if isActiveUser() && (
        isOwnerOrManager() || 
        hasPortfolioAccess(resource.data.portfolioId) || 
        (resource.data.entityType == 'system' && resource.data.userUid == request.auth.uid)
      );
      allow create: if isActiveUser() && (
        isOwnerOrManager() || 
        (request.resource.data.entityType == 'system' && request.resource.data.userUid == request.auth.uid)
      );
      allow update, delete: if false; 
    }
  }
}
